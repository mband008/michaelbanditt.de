---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const title = "Kontakt - Michael Banditt";
export const description = "Kontakt zu Michael Banditt – direkter Austausch zu Prozessoptimierung, Automatisierung, Veränderungsbegleitung und Zusammenarbeit.";
export const pageStyle = "contact-page.css";
---

<BaseLayout title={title} description={description} pageStyle={pageStyle}>
  <Header active="kontakt" />

  <main class="contact-page-modern">
    <section class="contact-hero-modern">
      <div class="contact-hero-copy">
        <span class="section-eyebrow">Kontakt</span>
        <h1>Lass uns über ein konkretes Thema sprechen.</h1>
        <p class="contact-lead">
          Der direkteste Weg ist eine kurze Nachricht per E-Mail oder LinkedIn.
          Ein paar Sätze zum Anliegen reichen völlig, damit ich den Kontext schnell einordnen kann.
        </p>
        <p>
          Besonders sinnvoll ist ein Austausch bei Themen rund um Prozessvereinfachung,
          Automatisierung, Veränderungsbegleitung oder operative Reibung zwischen Teams und Systemen.
        </p>

        <div class="hero-actions">
          <a href="mailto:hallo@michaelbanditt.de" class="cta-button">E-Mail schreiben</a>
          <a href="https://www.linkedin.com/in/michael-banditt/" class="secondary-button" target="_blank" rel="noopener noreferrer">LinkedIn öffnen</a>
        </div>

        <div class="hero-trust-list" aria-label="Themenfelder">
          <span>Prozessoptimierung</span>
          <span>Automatisierung</span>
          <span>Change-Begleitung</span>
          <span>Systempraxis</span>
        </div>
      </div>

      <aside class="contact-summary-card">
        <img
          src="images/17883980_111742692710237_3916354174887244207_n.jpg"
          alt="Porträt von Michael Banditt"
          class="contact-profile-image"
        >

        <div class="summary-card-content">
          <h2>Direkte Kontaktwege</h2>
          <div class="summary-list">
            <article>
              <span class="summary-label">E-Mail</span>
              <a href="mailto:hallo@michaelbanditt.de">hallo@michaelbanditt.de</a>
            </article>
            <article>
              <span class="summary-label">LinkedIn</span>
              <a href="https://www.linkedin.com/in/michael-banditt/" target="_blank" rel="noopener noreferrer">linkedin.com/in/michael-banditt</a>
            </article>
            <article>
              <span class="summary-label">Standort</span>
              <p>Dessau-Roßlau, Deutschland</p>
            </article>
          </div>
        </div>
      </aside>
    </section>

    <section class="contact-cards-grid" aria-label="Passende Anlässe für eine Nachricht">
      <article class="contact-card">
        <span class="contact-card-label">Typische Anliegen</span>
        <h2>Wann sich eine Nachricht lohnt</h2>
        <ul class="compact-list">
          <li>Ein Prozess ist unnötig kompliziert oder langsam geworden</li>
          <li>Automatisierung soll sinnvoll und realistisch aufgebaut werden</li>
          <li>Eine Veränderung muss verständlich eingeführt und begleitet werden</li>
        </ul>
      </article>

      <article class="contact-card">
        <span class="contact-card-label">Hilfreich zum Start</span>
        <h2>Was in der ersten Nachricht genügt</h2>
        <p>
          Beschreibe kurz das Problem, das Ziel und den größten Engpass.
          Mehr braucht es für einen guten ersten Austausch nicht.
        </p>
      </article>

      <article class="contact-card">
        <span class="contact-card-label">Direkter Weg</span>
        <h2>Ein Kontaktkanal reicht völlig</h2>
        <p>
          Am schnellsten geht es per E-Mail. Für Vernetzung oder eine erste Kontaktaufnahme
          ist auch LinkedIn ein guter Weg.
        </p>
      </article>
    </section>

    <section class="contact-cta-panel">
      <div>
        <span class="section-eyebrow">Direkter Austausch</span>
        <h2>Am besten starten wir mit einer kurzen, konkreten Nachricht.</h2>
        <p>
          Wenn du ein reales Thema hast, bei dem Klarheit, Struktur oder Entlastung gebraucht wird,
          freue ich mich über deine Nachricht.
        </p>
      </div>

      <div class="cta-panel-actions">
        <a href="mailto:hallo@michaelbanditt.de" class="cta-button">Jetzt schreiben</a>
        <a href="ueber-mich.html" class="secondary-button">Mehr über mich</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>