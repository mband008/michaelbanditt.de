---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const title = "Über mich - Michael Banditt";
export const description = "Michael Banditt – Problemlöser für Prozesse, Menschen und Systeme. Über mich, meine Erfahrung und meine Arbeitsweise.";
export const pageStyle = "about-page.css";
---

<BaseLayout title={title} description={description} pageStyle={pageStyle}>
  <Header active="about" />

  <main class="about-page-modern">
    <section class="profile-hero-modern">
      <div class="profile-hero-copy">
        <span class="section-eyebrow">Über mich</span>
        <h1>Ich arbeite an der Schnittstelle von Prozessen, Technik und Zusammenarbeit.</h1>
        <p class="profile-lead">
          Mein Profil verbindet operative Erfahrung, technisches Systemverständnis,
          Prozessoptimierung und Veränderungsbegleitung.
        </p>
        <p>
          Besonders wertvoll bin ich in Situationen, in denen Komplexität reduziert,
          Abläufe neu geordnet und Menschen sicher durch Veränderungen geführt werden müssen.
        </p>

        <div class="hero-actions">
          <a href="kontakt" class="cta-button">Kontakt aufnehmen</a>
          <a href="#stationen" class="secondary-button">Stationen ansehen</a>
        </div>
      </div>

      <aside class="profile-hero-card">
        <img
          src="images/17883980_111742692710237_3916354174887244207_n.jpg"
          alt="Porträt von Michael Banditt"
          class="profile-image-modern"
        >

        <div class="profile-facts">
          <div class="fact-item">
            <span class="fact-label">Schwerpunkt</span>
            <strong>Prozesse vereinfachen und wirksam umsetzen</strong>
          </div>
          <div class="fact-item">
            <span class="fact-label">Arbeitsstil</span>
            <strong>analytisch, pragmatisch, menschenorientiert</strong>
          </div>
          <div class="fact-item">
            <span class="fact-label">Passende Kontexte</span>
            <strong>Vereinfachung, Veränderung, technische Übersetzung</strong>
          </div>
        </div>

        <blockquote class="profile-quote">
          „Komplexität reduzieren. Lösungen anschlussfähig machen.“
        </blockquote>
      </aside>
    </section>

    <section class="proof-strip">
      <article class="proof-card">
        <span class="proof-number">12+</span>
        <p>Jahre Erfahrung in Service-, Support- und Prozessumfeldern</p>
      </article>
      <article class="proof-card">
        <span class="proof-number">3</span>
        <p>starke Kompetenzfelder: Prozess, Technik und Begleitung</p>
      </article>
      <article class="proof-card">
        <span class="proof-number">1</span>
        <p>klarer Fokus: reale Probleme verständlich und lösbar machen</p>
      </article>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-eyebrow">Profil</span>
        <h2>Wofür ich stehe</h2>
        <p>
          Nicht für abstrakte Konzepte, sondern für Verbesserungen, die im Alltag verstanden,
          angenommen und genutzt werden.
        </p>
      </div>

      <div class="pillar-grid">
        <article class="pillar-card">
          <h3>Komplexität greifbar machen</h3>
          <p>
            Ich strukturiere unübersichtliche Situationen und arbeite heraus,
            wo die eigentlichen Ursachen und Hebel liegen.
          </p>
        </article>
        <article class="pillar-card">
          <h3>Prozesse praktikabel neu ordnen</h3>
          <p>
            Ich denke in realen Verantwortlichkeiten, funktionierenden Abläufen
            und Lösungen, die Teams wirklich entlasten.
          </p>
        </article>
        <article class="pillar-card">
          <h3>Veränderung verständlich begleiten</h3>
          <p>
            Ich vermittle neue Arbeitsweisen so, dass daraus nicht nur ein Plan,
            sondern ein nutzbarer Standard wird.
          </p>
        </article>
      </div>
    </section>

    <section class="section-block" id="stationen">
      <div class="section-heading">
        <span class="section-eyebrow">Stationen</span>
        <h2>Beruflicher Weg</h2>
        <p>Mein Profil ist aus Praxis, Optimierungsarbeit und technischer Anschlussfähigkeit gewachsen.</p>
      </div>

      <div class="timeline-modern">
        <article class="timeline-entry">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3>Shiftmove GmbH</h3>
            <p class="timeline-role">Kundensupport, Prozessvereinfachung, interne Toolentwicklung</p>
            <p>
              Mitarbeit an Vereinfachungs- und Optimierungsvorhaben mit Fokus auf interne Lösungen,
              die operative Reibung reduzieren und im Alltag belastbar funktionieren.
            </p>
          </div>
        </article>
        <article class="timeline-entry">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3>Lohnexperte AG</h3>
            <p class="timeline-role">Projektmanager</p>
            <p>
              Projektkoordination, Stakeholder-Abstimmung und strukturierte Lösungsentwicklung
              in Konstellationen, in denen Überblick, Klarheit und saubere Kommunikation entscheidend sind.
            </p>
          </div>
        </article>
        <article class="timeline-entry">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3>Foundever B.V. & Co. KG / vormals SITEL GmbH</h3>
            <p class="timeline-role">Kundenservice, technischer Support, Angebotsmanagement, Prozessoptimierung</p>
            <p>
              Langjährige operative Erfahrung in Support- und Businesskontexten.
              Besonders prägend war die Arbeit an effizienteren Angebotsprozessen,
              Standardisierung und Automatisierung im Tagesgeschäft.
            </p>
          </div>
        </article>   
        
      </div>
    </section>

    <section class="section-block section-split">
      <div>
        <span class="section-eyebrow">Arbeitsweise</span>
        <h2>Wie ich typischerweise an Themen herangehe</h2>
        <p class="section-intro">
          Ich arbeite am besten, wenn die Herausforderung klar benannt ist und der Lösungsweg offen bleibt.
          Dann analysiere ich die Lage, priorisiere die relevanten Hebel und entwickle ein Vorgehen,
          das fachlich sauber und praktisch tragfähig ist.
        </p>
      </div>

      <div class="method-list">
        <article class="method-item">
          <span>01</span>
          <div>
            <h3>Ursachen statt Symptome klären</h3>
            <p>Ich schaue hinter Routinen, Ad-hoc-Lösungen und Reibung, um das eigentliche Problem sichtbar zu machen.</p>
          </div>
        </article>
        <article class="method-item">
          <span>02</span>
          <div>
            <h3>Lösungen realistisch aufbauen</h3>
            <p>Ich entwickle Strukturen, Zuständigkeiten und Abläufe, die nicht nur gut aussehen, sondern funktionieren.</p>
          </div>
        </article>
        <article class="method-item">
          <span>03</span>
          <div>
            <h3>Einführung mitdenken</h3>
            <p>Ich begleite Veränderungen so, dass Teams Orientierung gewinnen und neue Arbeitsweisen dauerhaft übernehmen können.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="section-eyebrow">Kompetenzen</span>
        <h2>Ausgewählte fachliche Schwerpunkte</h2>
      </div>

      <div class="tag-groups">
        <div class="tag-group">
          <h3>Prozess &amp; Organisation</h3>
          <div class="tag-list">
            <span>Prozessoptimierung</span>
            <span>Prozessautomatisierung</span>
            <span>Projektmanagement</span>
            <span>Stakeholder-Management</span>
            <span>Scrum / agile Zusammenarbeit</span>
          </div>
        </div>
        <div class="tag-group">
          <h3>Systeme &amp; Tools</h3>
          <div class="tag-list">
            <span>Zendesk</span>
            <span>Intercom / Fin</span>
            <span>HubSpot</span>
            <span>Salesforce</span>
            <span>Microsoft Dynamics CRM</span>
            <span>Microsoft Power Automate</span>
            <span>Jira</span>
            <span>YouTrack</span>
            <span>n8n</span>
            <span>Linux</span>
            <span>LLMs &amp; KI-Assistenten</span>
          </div>
        </div>
        <div class="tag-group">
          <h3>Zusammenarbeit &amp; Enablement</h3>
          <div class="tag-list">
            <span>Coaching</span>
            <span>Mentoring</span>
            <span>Training</span>
            <span>Wissensvermittlung</span>
            <span>Technischer Support</span>
          </div>
        </div>
      </div>
    </section>

    <section class="about-cta-panel">
      <div>
        <span class="section-eyebrow">Nächster Schritt</span>
        <h2>Lass uns über dein konkretes Thema sprechen.</h2>
        <p>
          Wenn du jemanden suchst, der Komplexität reduziert und Verbesserungen in die Umsetzung bringt,
          freue ich mich über deine Nachricht.
        </p>
      </div>
      <a href="kontakt" class="cta-button">Jetzt Kontakt aufnehmen</a>
    </section>
  </main>

  <Footer />
</BaseLayout>