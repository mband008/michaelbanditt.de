---
const { title, description, pageStyle } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/style.css">
  {pageStyle && <link rel="stylesheet" href={`/styles/${pageStyle}`} />}
</head>
<body>
  <slot />
</body>
</html>